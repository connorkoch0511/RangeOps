# Copy to .env (or export) before running the console / dashboard.
# All three components share ONE database.
POSTGRES_HOST=localhost
POSTGRES_PORT=5544
POSTGRES_DB=rangeops
POSTGRES_USER=rangeops
POSTGRES_PASSWORD=rangeops

# TCP endpoint the C sensor-sim listens on; the console connects here.
SIM_HOST=127.0.0.1
SIM_PORT=5555
